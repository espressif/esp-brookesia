            bool "Codec Recorder"
            depends on ESP_BOARD_DEV_AUDIO_CODEC_SUPPORT
            default n
            help
                Enable the recorder.

        menuconfig BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_PROCESSOR_IMPL
            bool "Audio Processor"
            depends on BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_CODEC_PLAYER_IMPL
            depends on BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_CODEC_RECORDER_IMPL
            default y
            help
                Enable the high-level audio processor backed by av_processor.

        if BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_CODEC_RECORDER_IMPL
            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_BITS
                int "Recorder bits"
                default 16
                help
                    The bits of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_CHANNELS
                int "Recorder channels"
                default 1
                help
                    The channels of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_SAMPLE_RATE
                int "Sample rate"
                default 16000
                help
                    The sample rate of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MIC_LAYOUT
                string "Mic layout"
                default "M"
                help
                    The mic layout of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_GENERAL_GAIN
                string "General gain"
                default "36.0"
                help
                    The general gain of the audio codec device, in dB.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_CHANNEL_GAINS
                string "Channel gains"
                default "{\"0\":0.0,\"1\":0.0}"
                help
                    The channel gains of the audio codec device, in dB.
                    JSON format is supported, the key is the channel index, the value is the gain in dB.
        endif
    endif

    menuconfig BROOKESIA_HAL_ADAPTOR_ENABLE_VIDEO_DEVICE
        bool "Video Device"
        default n
        help
            Enable the video processor device backed by av_processor.

    if BROOKESIA_HAL_ADAPTOR_ENABLE_VIDEO_DEVICE
        config BROOKESIA_HAL_ADAPTOR_VIDEO_KEEP_DEVICE_INITIALIZED_ON_RELEASE
            bool "Keep video device initialized after release"
            default y
            help
                Keep the video device initialized when its HAL reference count drops to zero.
                This avoids repeated camera/esp_video init-deinit cycles for expensive or non-idempotent camera drivers.
                The device is still deinitialized by force cleanup or process exit.

        menuconfig BROOKESIA_HAL_ADAPTOR_VIDEO_ENABLE_CAMERA_IMPL
            bool "Camera"
            default y
            help
                Enable the video camera discovery implementation.

