                    config BROOKESIA_HAL_ADAPTOR_WIFI_SOFTAP_PROVISION_DNS_THREAD_PRIORITY
                        int "Priority"
                        default 3
                        help
                            Priority of the provision DNS thread.

                    config BROOKESIA_HAL_ADAPTOR_WIFI_SOFTAP_PROVISION_DNS_THREAD_CORE_ID
                        int "Core ID"
                        default -1
                        range -1 1
                        help
                            Core ID of the provision DNS thread. `-1` means the core ID is not specified.
                endmenu
            endmenu
        endmenu
    endif

