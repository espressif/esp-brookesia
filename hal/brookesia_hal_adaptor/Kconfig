menu "ESP-Brookesia: Hal Adaptor Configurations"
    menuconfig BROOKESIA_HAL_ADAPTOR_ENABLE_DEBUG_LOG
        bool "Enable debug or lower level logs"
        default n

    if BROOKESIA_HAL_ADAPTOR_ENABLE_DEBUG_LOG
        menu "Audio"
            config BROOKESIA_HAL_ADAPTOR_AUDIO_DEVICE_ENABLE_DEBUG_LOG
                bool "Device"
                default n
                help
                    Enable debug or lower level logs for the audio device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_PLAYER_IMPL_ENABLE_DEBUG_LOG
                bool "Codec Player"
                default n
                help
                    Enable debug or lower level logs for the audio codec player.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_IMPL_ENABLE_DEBUG_LOG
                bool "Codec Recorder"
                default n
                help
                    Enable debug or lower level logs for the audio codec recorder.
        endmenu

        menu "Display"
            config BROOKESIA_HAL_ADAPTOR_DISPLAY_DEVICE_ENABLE_DEBUG_LOG
                bool "Device"
                default n
                help
                    Enable debug or lower level logs for the display device.

            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LEDC_BACKLIGHT_IMPL_ENABLE_DEBUG_LOG
                bool "LEDC Backlight"
                default n
                help
                    Enable debug or lower level logs for the display LEDC backlight.

            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LCD_PANEL_IMPL_ENABLE_DEBUG_LOG
                bool "LCD Panel"
                default n
                help
                    Enable debug or lower level logs for the display LCD panel.

            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LCD_TOUCH_IMPL_ENABLE_DEBUG_LOG
                bool "LCD Touch"
                default n
                help
                    Enable debug or lower level logs for the display LCD touch.
        endmenu

        menu "Storage"
            config BROOKESIA_HAL_ADAPTOR_STORAGE_DEVICE_ENABLE_DEBUG_LOG
                bool "Device"
                default n
                help
                    Enable debug or lower level logs for the storage device.

            config BROOKESIA_HAL_ADAPTOR_STORAGE_GENERAL_FS_ENABLE_DEBUG_LOG
                bool "General FS"
                default n
                help
                    Enable debug or lower level logs for the storage general file system.
        endmenu
    endif

    menuconfig BROOKESIA_HAL_ADAPTOR_ENABLE_AUDIO_DEVICE
        bool "Audio Device"
        default y
        help
            Enable the audio codec device.

    if BROOKESIA_HAL_ADAPTOR_ENABLE_AUDIO_DEVICE
        menuconfig BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_CODEC_PLAYER_IMPL
            bool "Codec Player"
            depends on ESP_BOARD_DEV_AUDIO_CODEC_SUPPORT
            default y
            help
                Enable the player.

        if BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_CODEC_PLAYER_IMPL
            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_PLAYER_VOLUME_DEFAULT
                int "Default volume"
                default 75
                range 0 100
                help
                    The default volume of the audio codec device, in percent.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_PLAYER_VOLUME_MIN
                int "Minimum volume"
                default 0
                range 0 100
                help
                    The minimum volume of the audio codec device, in percent.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_PLAYER_VOLUME_MAX
                int "Maximum volume"
                default 100
                range 0 100
                help
                    The maximum volume of the audio codec device, in percent.
        endif

        menuconfig BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_CODEC_RECORDER_IMPL
            bool "Codec Recorder"
            depends on ESP_BOARD_DEV_AUDIO_CODEC_SUPPORT
            default y
            help
                Enable the recorder.

        if BROOKESIA_HAL_ADAPTOR_AUDIO_ENABLE_CODEC_RECORDER_IMPL
            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_BITS
                int "Recorder bits"
                default 16
                help
                    The bits of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_CHANNELS
                int "Recorder channels"
                default 1
                help
                    The channels of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_SAMPLE_RATE
                int "Sample rate"
                default 16000
                help
                    The sample rate of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MIC_LAYOUT
                string "Mic layout"
                default "M"
                help
                    The mic layout of the audio codec device.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_GENERAL_GAIN
                string "General gain"
                default "36.0"
                help
                    The general gain of the audio codec device, in dB.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_CHANNEL_GAINS
                string "Channel gains"
                default "{\"0\":0.0,\"1\":0.0}"
                help
                    The channel gains of the audio codec device, in dB.
                    JSON format is supported, the key is the channel index, the value is the gain in dB.

            config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_ENABLE_MAIN_REFERENCE_ROUTE
                bool "Enable main/reference recorder routing"
                default n
                help
                    Read a raw multi-slot recorder stream from the board codec
                    and repack it into the configured 2-channel [main, reference]
                    output stream expected by the upper audio pipeline.

            if BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_ENABLE_MAIN_REFERENCE_ROUTE
                config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_RAW_CHANNELS
                    int "Raw recorder channels"
                    default 4
                    range 2 16
                    help
                        The number of raw TDM slots read from the recorder backend
                        before they are routed to the exposed [main, reference] pair.

                config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_GAIN_CHANNELS
                    int "Codec gain channels"
                    default BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_RAW_CHANNELS
                    range 1 16
                    help
                        The number of codec microphone gain channels available for
                        routed recorder gain control. This can differ from the raw
                        recorder slot count on boards where TDM slot order and codec
                        gain channel numbering are not the same thing.

                config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_MAIN_SLOT
                    int "Main microphone slot"
                    default 0
                    range 0 15
                    help
                        Zero-based raw slot index used as the main microphone signal.

                config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_MAIN_GAIN_CHANNEL
                    int "Main microphone gain channel"
                    default BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_MAIN_SLOT
                    range 0 15
                    help
                        Zero-based codec microphone channel index used when
                        applying gain to the routed main microphone signal.

                config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_REFERENCE_SLOT
                    int "Reference microphone slot"
                    default 1
                    range 0 15
                    help
                        Zero-based raw slot index used as the reference microphone signal.

                config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_REFERENCE_GAIN_CHANNEL
                    int "Reference microphone gain channel"
                    default BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_REFERENCE_SLOT
                    range 0 15
                    help
                        Zero-based codec microphone channel index used when
                        applying gain to the routed reference microphone signal.

                config BROOKESIA_HAL_ADAPTOR_AUDIO_CODEC_RECORDER_MAIN_REFERENCE_ROUTE_REFERENCE_GAIN_DB
                    string "Reference microphone gain"
                    default "0.0"
                    help
                        Additional gain, in dB, applied to the routed reference
                        microphone codec channel.
            endif
        endif
    endif

    menuconfig BROOKESIA_HAL_ADAPTOR_ENABLE_DISPLAY_DEVICE
        bool "Display Device"
        default y
        help
            Enable the display LCD device.

    if BROOKESIA_HAL_ADAPTOR_ENABLE_DISPLAY_DEVICE
        menuconfig BROOKESIA_HAL_ADAPTOR_DISPLAY_ENABLE_LEDC_BACKLIGHT_IMPL
            bool "LEDC Backlight"
            depends on ESP_BOARD_DEV_LEDC_CTRL_SUPPORT
            default y
            help
                Enable the LEDC backlight.

        if BROOKESIA_HAL_ADAPTOR_DISPLAY_ENABLE_LEDC_BACKLIGHT_IMPL
            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LEDC_BACKLIGHT_BRIGHTNESS_DEFAULT
                int "Default brightness"
                default 90
                range 0 100
                help
                    The default brightness of the display LCD backlight, in percent.

            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LEDC_BACKLIGHT_BRIGHTNESS_MIN
                int "Minimum brightness"
                default 20
                range 0 100
                help
                    The minimum brightness of the display LCD backlight, in percent.

            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LEDC_BACKLIGHT_BRIGHTNESS_MAX
                int "Maximum brightness"
                default 100
                range 0 100
                help
                    The maximum brightness of the display LCD backlight, in percent.
        endif

        menuconfig BROOKESIA_HAL_ADAPTOR_DISPLAY_ENABLE_LCD_PANEL_IMPL
            bool "LCD Panel"
            depends on ESP_BOARD_DEV_DISPLAY_LCD_SUPPORT
            default y
            help
                Enable the LCD panel.

        if BROOKESIA_HAL_ADAPTOR_DISPLAY_ENABLE_LCD_PANEL_IMPL
            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LCD_PANEL_H_RES
                int "Horizontal resolution in pixels"
                default 0
                range 0 65535
                help
                    The horizontal resolution of the display LCD panel, in pixels.
                    This value is used to provide the LCD panel resolution information for the CMake stage.

            config BROOKESIA_HAL_ADAPTOR_DISPLAY_LCD_PANEL_V_RES
                int "Vertical resolution in pixels"
                default 0
                range 0 65535
                help
                    The vertical resolution of the display LCD panel, in pixels.
                    This value is used to provide the LCD panel resolution information for the CMake stage.
        endif

        menuconfig BROOKESIA_HAL_ADAPTOR_DISPLAY_ENABLE_LCD_TOUCH_IMPL
            bool "LCD Touch"
            depends on ESP_BOARD_DEV_LCD_TOUCH_I2C_SUPPORT
            default y
            help
                Enable the LCD touch.
    endif

    menuconfig BROOKESIA_HAL_ADAPTOR_ENABLE_STORAGE_DEVICE
        bool "Storage Device"
        default y
        help
            Enable the storage device.

    if BROOKESIA_HAL_ADAPTOR_ENABLE_STORAGE_DEVICE
        menuconfig BROOKESIA_HAL_ADAPTOR_STORAGE_ENABLE_GENERAL_FS_IMPL
            bool "General FS"
            default y
            help
                Enable the storage general file system.

        if BROOKESIA_HAL_ADAPTOR_STORAGE_ENABLE_GENERAL_FS_IMPL
            config BROOKESIA_HAL_ADAPTOR_STORAGE_GENERAL_FS_ENABLE_SPIFFS
                bool "SPIFFS"
                depends on ESP_BOARD_DEV_FS_SPIFFS_SUPPORT
                default y
                help
                    Enable the SPIFFS.

            config BROOKESIA_HAL_ADAPTOR_STORAGE_GENERAL_FS_ENABLE_SDCARD
                bool "SD card (FATFS)"
                depends on ESP_BOARD_DEV_FS_FAT_SUPPORT
                default y
                help
                    Enable the SD card (FATFS).
        endif
    endif
endmenu
