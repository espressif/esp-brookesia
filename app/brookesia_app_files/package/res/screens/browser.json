{
    "type": "viewScreen",
    "id": "browser",
    "commonProps": {
        "scrollable": false
    },
    "styleRefs": [
        "app.page"
    ],
    "children": [
        {
            "type": "container",
            "id": "page",
            "commonProps": {
                "scrollable": false
            },
            "placement": {
                "mode": "absolute",
                "x": "${constant.files.layout.pagePadding}",
                "y": "${constant.files.layout.contentTop}",
                "width": "${expr(${env.widthDp} - ${constant.files.layout.pagePadding} * 2)}",
                "height": "${expr(${env.heightDp} - ${constant.files.layout.contentTop} - ${constant.files.layout.pagePadding})}"
            },
            "layout": {
                "type": "flex",
                "flexFlow": "column",
                "gap": "${constant.files.layout.pageGap}"
            },
            "children": [
                {
                    "type": "container",
                    "id": "list",
                    "styleRefs": [
                        "app.card"
                    ],
                    "style": {
                        "padding": "${constant.files.layout.cardPadding}"
                    },
                    "layout": {
                        "type": "flex",
                        "flexFlow": "column",
                        "gap": "4dp"
                    },
                    "commonProps": {
                        "scrollable": true
                    },
                    "placement": {
                        "mode": "flow",
                        "width": "match",
                        "height": "match"
                    },
                    "children": [
                        {
                            "type": "container",
                            "id": "items",
                            "layout": {
                                "type": "flex",
                                "flexFlow": "column",
                                "gap": "4dp"
                            },
                            "placement": {
                                "mode": "flow",
                                "width": "match",
                                "height": "wrap",
                                "alignSelf": "stretch"
                            }
                        }
                    ]
                }
            ]
        }
    ]
}
