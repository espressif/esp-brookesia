{
    "version": "0.1.0",
    "assets": [
        "constants/default.json",
        "i18n/en.json",
        "images/index.json",
        "templates/press_scale.json",
        "screens/app_store.json",
        "templates/app_store_item.json",
        "flows/app_store.json"
    ],
    "variants": [
        {
            "when": "${expr(${env.widthDp} == 1024dp && ${env.heightDp} == 600dp)}",
            "assets": [
                "constants/1024x600.json"
            ]
        },
        {
            "when": "${expr(${env.widthDp} == 800dp && ${env.heightDp} == 480dp)}",
            "assets": [
                "constants/800x480.json"
            ]
        },
        {
            "when": "${expr(${env.widthDp} < ${env.heightDp})}",
            "assets": [
                "constants/portrait.json"
            ]
        },
        {
            "when": "${expr(${env.language} == \"zh_CN\")}",
            "assets": [
                "i18n/zh_CN.json"
            ]
        }
    ]
}
