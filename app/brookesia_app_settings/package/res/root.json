{
    "version": "0.1.0",
    "assets": [
        "constants/default.json",
        "images/index.json",
        "screens/settings_home.json",
        "screens/my_device.json",
        "screens/wifi.json",
        "screens/wifi_connect.json",
        "screens/sound.json",
        "screens/display.json",
        "screens/header.json",
        "screens/more.json",
        "screens/language.json",
        "screens/time_zone.json",
        "screens/debug.json",
        "templates/press_item.json",
        "templates/settings_card.json",
        "templates/search_card.json",
        "templates/debug_slider_row.json",
        "templates/setting_row.json",
        "templates/slider_row.json",
        "templates/switch_row.json",
        "templates/hardware_group_card.json",
        "templates/wifi_network_item.json",
        "templates/wifi_connected_item.json",
        "templates/theme_mode_card.json",
        "templates/nav_menu_item.json",
        "templates/menu_item.json",
        "templates/page_header.json",
        "flows/content.json",
        "flows/header.json"
    ],
    "variants": [
        {
            "when": "${expr(${env.widthDp} == 1024dp && ${env.heightDp} == 600dp)}",
            "assets": [
                "constants/1024x600.json"
            ]
        },
        {
            "when": "${expr(${env.widthDp} == 800dp && ${env.heightDp} == 480dp)}",
            "assets": [
                "constants/800x480.json"
            ]
        },
        {
            "when": "${expr(${env.widthDp} < ${env.heightDp})}",
            "assets": [
                "constants/portrait.json"
            ]
        }
    ]
}
