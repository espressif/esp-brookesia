{
    "type": "viewScreen",
    "id": "more",
    "mountMode": "dynamic",
    "commonProps": {
        "scrollable": false
    },
    "styleRefs": [
        "app.page"
    ],
    "children": [
        {
            "type": "container",
            "id": "page",
            "commonProps": {
                "scrollable": true
            },
            "layout": {
                "type": "flex",
                "flexFlow": "column",
                "gap": "${constant.settings.layout.pageGap}"
            },
            "placement": {
                "mode": "absolute",
                "x": "${constant.settings.layout.pageX}",
                "y": "${constant.settings.layout.pageY}",
                "width": "${constant.settings.layout.pageWidth}",
                "height": "${constant.settings.layout.pageHeight}"
            },
            "children": [
                {
                    "type": "label",
                    "id": "system_caption",
                    "styleRefs": [
                        "app.caption"
                    ],
                    "labelProps": {
                        "text": "System settings"
                    },
                    "placement": {
                        "mode": "flow"
                    },
                    "bindings": {
                        "labelProps.text": "labelProps.text"
                    }
                },
                {
                    "type": "container",
                    "id": "language_card",
                    "commonProps": {
                        "scrollable": false
                    },
                    "styleRefs": [
                        "app.card"
                    ],
                    "style": {
                        "padding": "18dp"
                    },
                    "layout": {
                        "type": "flex",
                        "flexFlow": "column",
                        "gap": "0dp"
                    },
                    "placement": {
                        "mode": "flow",
                        "width": "match",
                        "height": "wrap",
                        "alignSelf": "stretch"
                    },
                    "children": [
                        {
                            "type": "templateRef",
                            "id": "language",
                            "templateId": "nav_menu_item",
                            "overrides": {
                                ".": {
                                    "events": [
                                        {
                                            "type": "clicked",
                                            "action": "settings.open.language"
                                        }
                                    ]
                                },
                                "icon": {
                                    "imageProps": {
                                        "src": "${image.more.language}"
                                    }
                                },
                                "title_box/title": {
                                    "labelProps": {
                                        "text": ""
                                    }
                                },
                                "value_box/value": {
                                    "labelProps": {
                                        "text": ""
                                    }
                                }
                            }
                        },
                        {
                            "type": "templateRef",
                            "id": "time_zone",
                            "templateId": "nav_menu_item",
                            "overrides": {
                                ".": {
                                    "events": [
                                        {
                                            "type": "clicked",
                                            "action": "settings.open.time_zone"
                                        }
                                    ]
                                },
                                "icon": {
                                    "imageProps": {
                                        "src": "${image.more.time_zone}"
                                    }
                                },
                                "title_box/title": {
                                    "labelProps": {
                                        "text": "Time zone"
                                    }
                                },
                                "value_box/value": {
                                    "labelProps": {
                                        "text": "Asia/Shanghai"
                                    }
                                }
                            }
                        }
                    ]
                }
            ]
        }
    ]
}
