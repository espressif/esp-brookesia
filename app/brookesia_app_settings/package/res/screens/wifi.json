{
    "type": "viewScreen",
    "id": "wifi",
    "commonProps": {
        "scrollable": false
    },
    "styleRefs": [
        "app.page"
    ],
    "children": [
        {
            "type": "container",
            "id": "page",
            "commonProps": {
                "scrollable": true
            },
            "layout": {
                "type": "flex",
                "flexFlow": "column",
                "gap": "${constant.settings.layout.pageGap}"
            },
            "placement": {
                "mode": "absolute",
                "x": "${constant.settings.layout.pageX}",
                "y": "${constant.settings.layout.pageY}",
                "width": "${constant.settings.layout.pageWidth}",
                "height": "${constant.settings.layout.pageHeight}"
            },
            "children": [
                {
                    "type": "container",
                    "id": "wifi_status_card",
                    "bindings": {
                        "style.opacity": "opacity"
                    },
                    "commonProps": {
                        "scrollable": false
                    },
                    "styleRefs": [
                        "app.card"
                    ],
                    "style": {
                        "padding": "${constant.settings.layout.cardPadding}"
                    },
                    "layout": {
                        "type": "flex",
                        "flexFlow": "row",
                        "mainAlign": "spaceBetween",
                        "crossAlign": "center"
                    },
                    "placement": {
                        "mode": "flow",
                        "width": "match",
                        "height": "${constant.settings.layout.wifiStatusCardHeight}",
                        "alignSelf": "stretch"
                    },
                    "children": [
