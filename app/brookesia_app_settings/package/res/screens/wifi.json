                            },
                            "bindings": {
                                "labelProps.text": "labelProps.text"
                            }
                        },
                        {
                            "type": "switch",
                            "id": "wifi_switch",
                            "bindings": {
                                "toggleProps.checked": "checked",
                                "commonProps.disabled": "disabled"
                            },
                            "events": [
                                {
                                    "type": "valueChanged",
                                    "action": "settings.wifi.toggle"
                                }
                            ],
                            "toggleProps": {
                                "checked": false
                            },
                            "styleRefs": [
                                "app.switch"
                            ],
                            "placement": {
                                "mode": "flow",
                                "alignSelf": "center",
                                "width": "${constant.settings.layout.switchWidth}",
                                "height": "${constant.settings.layout.switchHeight}"
                            }
                        }
                    ]
                },
                {
                    "type": "container",
                    "id": "wifi_content",
                    "commonProps": {
                        "hidden": true,
                        "scrollable": false
                    },
                    "bindings": {
                        "commonProps.hidden": "commonProps.hidden"
                    },
                    "layout": {
                        "type": "flex",
                        "flexFlow": "column",
                        "gap": "${constant.settings.layout.pageGap}"
                    },
                    "placement": {
                        "mode": "flow",
                        "width": "match",
                        "alignSelf": "stretch"
                    },
                    "children": [
                        {
                            "type": "templateRef",
                            "id": "connected",
                            "templateId": "wifi_connected_item",
                            "bindings": {
                                "commonProps.hidden": "commonProps.hidden"
                            },
                            "overrides": {
                                ".": {
                                    "events": [
                                        {
                                            "type": "clicked",
                                            "action": "settings.wifi.disconnect"
                                        }
                                    ]
                                }
                            }
                        },
                        {
                            "type": "label",
                            "id": "saved_caption",
                            "styleRefs": [
                                "app.caption"
