{
    "type": "viewScreen",
    "id": "language",
    "commonProps": {
        "scrollable": false
    },
    "styleRefs": [
        "app.page"
    ],
    "children": [
        {
            "type": "container",
            "id": "page",
            "commonProps": {
                "scrollable": true
            },
            "layout": {
                "type": "flex",
                "flexFlow": "column",
                "gap": "${constant.settings.layout.pageGap}"
            },
            "placement": {
                "mode": "absolute",
                "x": "${constant.settings.layout.pageX}",
                "y": "${constant.settings.layout.pageY}",
                "width": "${constant.settings.layout.pageWidth}",
                "height": "${constant.settings.layout.pageHeight}"
            },
            "children": [
                {
                    "type": "label",
                    "id": "system_caption",
                    "styleRefs": [
                        "app.caption"
                    ],
                    "labelProps": {
                        "text": ""
                    },
                    "placement": {
                        "mode": "flow"
                    },
                    "bindings": {
                        "labelProps.text": "labelProps.text"
                    }
                },
                {
                    "type": "container",
                    "id": "language_card",
                    "styleRefs": [
                        "app.card"
                    ],
                    "style": {
                        "padding": "18dp"
                    },
                    "layout": {
                        "type": "flex",
                        "flexFlow": "column",
                        "gap": "0dp"
                    },
                    "placement": {
                        "mode": "flow",
                        "width": "match",
                        "height": "wrap",
                        "alignSelf": "stretch"
                    },
                    "children": [
                        {
                            "type": "container",
                            "id": "list",
                            "layout": {
                                "type": "flex",
                                "flexFlow": "column",
                                "gap": "0dp"
                            },
                            "placement": {
                                "mode": "flow",
                                "width": "match",
                                "height": "wrap",
                                "alignSelf": "stretch"
                            },
                            "children": []
                        }
                    ]
                }
            ]
        }
    ]
}
