{
    "type": "viewTemplate",
    "id": "hardware_group_card",
    "node": {
        "type": "container",
        "commonProps": {
            "scrollable": false
        },
        "layout": {
            "type": "flex",
            "flexFlow": "column",
            "gap": "6dp"
        },
        "placement": {
            "mode": "flow",
            "width": "match",
            "height": "wrap",
            "alignSelf": "stretch"
        },
        "children": [
            {
                "type": "label",
                "id": "title",
                "styleRefs": [
                    "app.caption"
                ],
                "labelProps": {
                    "text": "Display"
                },
                "placement": {
                    "mode": "flow",
                    "width": "match"
                }
            },
            {
                "type": "container",
                "id": "card",
                "styleRefs": [
                    "app.card"
                ],
                "style": {
                    "padding": "${constant.settings.layout.cardPadding}"
                },
                "layout": {
                    "type": "flex",
                    "flexFlow": "column",
                    "gap": "6dp"
                },
                "placement": {
                    "mode": "flow",
                    "width": "match",
                    "height": "wrap",
                    "alignSelf": "stretch"
                },
                "children": [
                    {
                        "type": "label",
                        "id": "details",
                        "styleRefs": [
                            "app.cardSubtitle"
                        ],
                        "labelProps": {
                            "text": ""
                        },
                        "placement": {
                            "mode": "flow",
                            "width": "match"
                        }
                    }
                ]
            }
        ]
    }
}
