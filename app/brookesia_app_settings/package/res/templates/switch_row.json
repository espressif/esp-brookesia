{
    "type": "viewTemplate",
    "id": "switch_row",
    "node": {
        "type": "container",
        "commonProps": {
            "scrollable": false
        },
        "bindings": {
            "commonProps.disabled": "disabled",
            "style.opacity": "opacity"
        },
        "layout": {
            "type": "grid",
            "gridTemplateColumns": [
                "match",
                "${constant.settings.layout.switchColumnWidth}"
            ],
            "gridTemplateRows": [
                "match"
            ],
            "gap": "16dp",
            "crossAlign": "center"
        },
        "placement": {
            "mode": "flow",
            "width": "match",
            "height": "72dp",
            "alignSelf": "stretch"
        },
        "children": [
            {
                "type": "container",
                "id": "text",
                "layout": {
                    "type": "flex",
                    "flexFlow": "column",
                    "gap": "4dp"
                },
                "placement": {
                    "mode": "flow",
                    "gridColumn": 0,
                    "gridRow": 0,
                    "alignSelf": "stretch"
                },
                "children": [
                    {
                        "type": "label",
                        "id": "title",
                        "styleRefs": [
                            "app.listItemTitle"
                        ],
                        "bindings": {
                            "labelProps.text": "labelProps.text"
                        },
                        "labelProps": {
                            "text": "Switch"
                        },
                        "placement": {
                            "mode": "flow"
                        }
                    },
                    {
                        "type": "label",
                        "id": "subtitle",
                        "styleRefs": [
                            "app.cardSubtitle"
                        ],
                        "bindings": {
                            "labelProps.text": "labelProps.text"
                        },
                        "labelProps": {
                            "text": ""
                        },
                        "placement": {
                            "mode": "flow"
                        }
                    }
                ]
            },
            {
                "type": "switch",
                "id": "toggle",
                "toggleProps": {
                    "checked": true
                },
                "styleRefs": [
                    "app.switch"
                ],
                "bindings": {
                    "commonProps.disabled": "disabled",
                    "toggleProps.checked": "checked"
                },
                "placement": {
                    "mode": "flow",
                    "gridColumn": 1,
                    "gridRow": 0,
                    "alignSelf": "center",
                    "width": "${constant.settings.layout.switchWidth}",
                    "height": "${constant.settings.layout.switchHeight}"
                }
            }
        ]
    }
}
