{
    "type": "viewTemplate",
    "id": "slider_row",
    "node": {
        "type": "container",
        "commonProps": {
            "scrollable": false
        },
        "bindings": {
            "commonProps.disabled": "disabled",
            "style.opacity": "opacity"
        },
        "layout": {
            "type": "flex",
            "flexFlow": "column",
            "gap": "10dp"
        },
        "placement": {
            "mode": "flow",
            "width": "match",
            "height": "94dp",
            "alignSelf": "stretch"
        },
        "children": [
            {
                "type": "label",
                "id": "title",
                "styleRefs": [
                    "app.cardTitle"
                ],
                "bindings": {
                    "labelProps.text": "labelProps.text"
                },
                "labelProps": {
                    "text": "Slider"
                },
                "placement": {
                    "mode": "flow"
                }
            },
            {
                "type": "slider",
                "id": "slider",
                "rangeProps": {
                    "min": 0,
                    "max": 100,
                    "value": 50
                },
                "bindings": {
                    "commonProps.disabled": "disabled",
                    "rangeProps.value": "value"
                },
                "styleRefs": [
                    "app.slider"
                ],
                "placement": {
                    "mode": "flow",
                    "height": "${constant.settings.layout.sliderHeight}",
                    "width": "match",
                    "alignSelf": "stretch"
                }
            }
        ]
    }
}
