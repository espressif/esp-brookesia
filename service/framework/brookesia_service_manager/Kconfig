menu "ESP-Brookesia: Service Manager Configurations"
    config BROOKESIA_SERVICE_MANAGER_BOOST_ENABLED
        bool
        select BOOST_THREAD_ENABLED
        select BOOST_JSON_ENABLED
        default y
        help
            Enable Boost libraries.

    menuconfig BROOKESIA_SERVICE_MANAGER_ENABLE_DEBUG_LOG
        bool "Enable debug or lower level logs"
        default n

    if BROOKESIA_SERVICE_MANAGER_ENABLE_DEBUG_LOG
        config BROOKESIA_SERVICE_MANAGER_EVENT_ENABLE_DEBUG_LOG
            bool "Event"
            default y

        config BROOKESIA_SERVICE_MANAGER_FUNCTION_ENABLE_DEBUG_LOG
            bool "Function"
            default y

        config BROOKESIA_SERVICE_MANAGER_SERVICE_ENABLE_DEBUG_LOG
            bool "Service"
            default y
    endif

    config BROOKESIA_SERVICE_MANAGER_DEFAULT_CALL_FUNCTION_TIMEOUT_MS
        int "Default call function timeout (ms)"
        default 1000
        help
            The default timeout of the call function. If the timeout is not specified when calling the function, this value will be used.
            When debug log level is enabled, a large number of logs may cause call function timeouts. In this case, this value can be increased to avoid timeouts.

    menu "Main Scheduler"
        menu "General"
            config BROOKESIA_SERVICE_MANAGER_WORKER_NAME
                string "Name"
                default "SvcMgrMain"
                help
                    The name of the worker thread.

            config BROOKESIA_SERVICE_MANAGER_WORKER_PRIORITY
                int "Priority"
                default 5
                help
                    The priority of the worker thread.

            config BROOKESIA_SERVICE_MANAGER_WORKER_STACK_SIZE
                int "Stack size"
                default 15360
                help
                    The stack size of the worker thread.

            config BROOKESIA_SERVICE_MANAGER_WORKER_STACK_IN_EXT
                bool "Stack in external memory"
                depends on SPIRAM
                default y
                help
                    Whether the stack of the worker thread is in external memory. If enabled, the stack will be allocated in external memory.

            config BROOKESIA_SERVICE_MANAGER_WORKER_POLL_INTERVAL_MS
                int "Poll interval (ms)"
                default 5
                range 1 10
                help
                    The interval of the worker poll.
        endmenu

        config BROOKESIA_SERVICE_MANAGER_WORKER_NUM
            int "Number of workers"
            default 3
            range 1 4
            help
                The number of workers.

        config BROOKESIA_SERVICE_MANAGER_WORKER_0_CORE_ID
            int "Core ID of Worker 0"
            range -1 1
            default 0
            help
                The core ID of Worker 0. `-1` means the core ID is not specified.

        if BROOKESIA_SERVICE_MANAGER_WORKER_NUM >= 2
            config BROOKESIA_SERVICE_MANAGER_WORKER_1_CORE_ID
                int "Core ID of Worker 1"
                range -1 1
                default 1
                help
                    The core ID of Worker 1. `-1` means the core ID is not specified.
        endif

        if BROOKESIA_SERVICE_MANAGER_WORKER_NUM >= 3
            config BROOKESIA_SERVICE_MANAGER_WORKER_2_CORE_ID
                int "Core ID of Worker 2"
                range -1 1
                default -1
                help
                    The core ID of Worker 2. `-1` means the core ID is not specified.
        endif

        if BROOKESIA_SERVICE_MANAGER_WORKER_NUM >= 4
            config BROOKESIA_SERVICE_MANAGER_WORKER_3_CORE_ID
                int "Core ID of Worker 3"
                range -1 1
                default -1
                help
                    The core ID of Worker 3. `-1` means the core ID is not specified.
        endif
    endmenu

    menuconfig BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_ENABLE
        bool "Secondary Scheduler"
        default y if BROOKESIA_SERVICE_MANAGER_WORKER_STACK_IN_EXT
        default n
        help
            Enable a second manager-owned task scheduler for services that
            need shared worker threads with internal SRAM stacks.

    if BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_ENABLE
        menu "General"
            config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_NAME
                string "Name"
                default "SvcMgrSec"
                help
                    The base name of the secondary scheduler worker thread.

            config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_PRIORITY
                int "Priority"
                default 5
                help
                    The priority of the secondary scheduler worker thread.

            config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_STACK_SIZE
                int "Stack size"
                default 7168
                help
                    The stack size of the secondary scheduler worker thread.
                    The stack is always allocated from internal SRAM.

            config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_POLL_INTERVAL_MS
                int "Poll interval (ms)"
                default 5
                range 1 10
                help
                    The interval of the secondary scheduler worker poll.
        endmenu

        config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_NUM
            int "Number of workers"
            default 2
            range 1 4
            help
                The number of secondary scheduler workers.

        config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_0_CORE_ID
            int "Core ID of Worker 0"
            range -1 1
            default 0
            help
                The core ID of Worker 0. `-1` means the core ID is not specified.

        if BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_NUM >= 2
            config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_1_CORE_ID
                int "Core ID of Worker 1"
                range -1 1
                default 1
                help
                    The core ID of Worker 1. `-1` means the core ID is not specified.
        endif

        if BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_NUM >= 3
            config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_2_CORE_ID
                int "Core ID of Worker 2"
                range -1 1
                default -1
                help
                    The core ID of Worker 2. `-1` means the core ID is not specified.
        endif

        if BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_NUM >= 4
            config BROOKESIA_SERVICE_MANAGER_SECONDARY_SCHEDULER_WORKER_3_CORE_ID
                int "Core ID of Worker 3"
                range -1 1
                default -1
                help
                    The core ID of Worker 3. `-1` means the core ID is not specified.
        endif
    endif
endmenu
