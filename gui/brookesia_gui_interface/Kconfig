menu "ESP-Brookesia: GUI Interface Configurations"
    menuconfig BROOKESIA_GUI_INTERFACE_ENABLE_DEBUG_LOG
        bool "Enable debug or lower level logs"
        default n

    if BROOKESIA_GUI_INTERFACE_ENABLE_DEBUG_LOG
        config BROOKESIA_GUI_INTERFACE_DATA_STORE_ENABLE_DEBUG_LOG
            bool "Data store"
            default y

        config BROOKESIA_GUI_INTERFACE_PARSER_ENABLE_DEBUG_LOG
            bool "Parser"
            default y

        config BROOKESIA_GUI_INTERFACE_RUNTIME_ENABLE_DEBUG_LOG
            bool "Runtime"
            default y

        config BROOKESIA_GUI_INTERFACE_VALIDATOR_ENABLE_DEBUG_LOG
            bool "Validator"
            default y

        config BROOKESIA_GUI_INTERFACE_WIDGET_ENABLE_DEBUG_LOG
            bool "Widget"
            default y
    endif

    config BROOKESIA_GUI_INTERFACE_ENABLE_MEMORY_TRACE
        bool "Enable runtime memory/heap trace logs (profiling)"
        default n
        help
            When enabled, the GUI runtime emits detailed [HeapTrace] logs and
            per-substep PSRAM accounting while loading documents and creating
            views (e.g. gui.load.split, gui.create_view, gui.binding.signals).
            This is a profiling aid only; keep it disabled in production builds
            because the extra snapshots and logging add CPU and log overhead.

    config BROOKESIA_GUI_INTERFACE_ENABLE_PROFILE_LOG
        bool "Enable parser/runtime profile logs"
        default y if BROOKESIA_GUI_INTERFACE_ENABLE_MEMORY_TRACE
        default n
        help
            When enabled, the GUI parser and runtime emit stage-by-stage timing
            logs while loading JSON UI documents and building views. This is
            useful for startup latency diagnosis, but should stay disabled in
            normal builds because log formatting and serial output perturb the
            timings being measured.

    menuconfig BROOKESIA_GUI_INTERFACE_ENABLE_EXAMPLES
        bool "Enable JSON-UI example suite"
        default y
        help
            Master switch for the JSON-UI example plugins. Each example below can
            be toggled individually; disabled examples are not compiled, linked,
            or shown in the example menu.

